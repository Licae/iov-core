# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EXECUTION_MODE: Optional. Supported values:
# - python: python adapter
# - shell/script: shell adapter
# - simulate: built-in fake executor, only for local debugging
EXECUTION_MODE="python"

# EXECUTION_SCRIPT: Optional when EXECUTION_MODE=script.
# Supported placeholders: {{taskId}} {{testCaseId}} {{suiteId}} {{assetId}} {{title}} {{protocol}}
# Example:
# EXECUTION_SCRIPT="bash scripts/run_case.sh {{testCaseId}}"
EXECUTION_SCRIPT=""

# PYTHON_EXECUTABLE: Optional when using the python adapter.
PYTHON_EXECUTABLE="python3"

# PYTHON_SECURITY_RUNNER: Optional when using the python adapter.
# Default points to scripts/security_runner.py in the repo root.
PYTHON_SECURITY_RUNNER=""

# SSH real-check credentials for scripts/ssh_access_check.py
SSH_TEST_PORT="22"
SSH_TEST_ALLOWED_USER=""
SSH_TEST_ALLOWED_PASSWORD=""
SSH_TEST_DENIED_USER=""
SSH_TEST_DENIED_PASSWORD=""
